# =============================================================================
# Go BFF — .env.example
# -----------------------------------------------------------------------------
# Copy this file to `.env` and replace placeholder values before running.
# `.env` is gitignored; this template is safe to commit.
# See MAINTENANCE.md §4 for the full variable reference.
# =============================================================================


# -----------------------------------------------------------------------------
# Required — service runtime
# -----------------------------------------------------------------------------

# TCP port the BFF listens on. Used by the Dockerfile EXPOSE and by health probes.
GO_SERVICE_PORT=8080

# Selects environment-specific behaviour:
#   - "deployment"  → Swagger UI disabled; CORS uses DEPLOYMENT_FRONTEND_URL.
#   - any other value (or unset) → Swagger UI enabled at /swagger/;
#     CORS uses LOCAL_FRONTEND_URL.
ENV=local


# -----------------------------------------------------------------------------
# Required — database
# -----------------------------------------------------------------------------

# Azure PostgreSQL connection string. TLS is mandatory — the `sslmode=require`
# query parameter must be present.
# Example: postgresql://user:secret@my-pg.postgres.database.azure.com:5432/rescue?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require


# -----------------------------------------------------------------------------
# Required — CORS allowlist
# -----------------------------------------------------------------------------

# Used when ENV=deployment. Must exactly match the deployed frontend origin
# (scheme + host + port). No wildcards.
DEPLOYMENT_FRONTEND_URL=https://your-frontend.example.com

# Used when ENV≠deployment (local dev). Typically the Vite dev server.
LOCAL_FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Optional — AI capabilities
# -----------------------------------------------------------------------------
# If BOTH keys below are unset, the BFF starts without AI features. The
# following route groups will not be registered and respond with 404:
#   - /api/ai/{chat,stream}
#   - /api/knowledge/{transcribe,translate,tts,languages,voice-search}
# The rest of the service continues to operate.

# OpenAI API key — enables Whisper STT, TTS, and chat-via-OpenAI.
OPENAI_API_KEY=

# Anthropic API key — enables Claude chat, translation, and voice-intent.
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Optional — routing
# -----------------------------------------------------------------------------
# When unset, POST /api/route/calculate returns 503 Service Unavailable.

# OpenRouteService API key.
ORS_API_KEY=
