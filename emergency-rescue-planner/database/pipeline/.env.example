# Azure-managed PostgreSQL DSN for the data-pipeline scripts.
# Copy this file to `.env` in this directory and fill in real credentials.
# `.env` is gitignored at the repo root; this `.env.example` template is safe to commit.
#
# Format: postgresql+psycopg2://<user>:<password>@<host>:5432/<database>?sslmode=require
# The `sslmode=require` query parameter is mandatory — Azure-managed Postgres rejects plaintext.

DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>:5432/<database>?sslmode=require
